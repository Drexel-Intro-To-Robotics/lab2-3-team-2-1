<?xml version="1.0"?>
<launch>

  <!-- Load controller config onto parameter server -->
  <rosparam file="$(find lab3)/config/controllers.yaml"
            command="load"/>

  <!-- Start the controller manager -->
  <node name="controller_manager"
        pkg="controller_manager"
        type="controller_manager"
        respawn="false"
        output="screen"
        args="spawn
              joint_state_controller
              arm_controller
              gripper_controller"/>

</launch>