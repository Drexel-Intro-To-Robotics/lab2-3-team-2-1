<?xml version="1.0"?>
<launch>

  <arg name="pipeline" default="ompl"/>

  <!-- 1. Robot bringup — starts hardware, controller_manager,
          arm_controller, gripper_controller, joint_state_controller -->
  <include file="$(find turtlebot3_manipulation_bringup)/launch/turtlebot3_manipulation_bringup.launch"/>

  <!-- 2. MoveIt! move_group — motion planning server -->
  <include file="$(find turtlebot3_manipulation_moveit_config)/launch/move_group.launch">
    <arg name="allow_trajectory_execution" value="true"/>
    <arg name="fake_execution"             value="false"/>
    <arg name="pipeline"                   value="$(arg pipeline)"/>
    <arg name="info"                       value="true"/>
  </include>

  <!-- Launch TurtleBot3 Manipulation MoveIt RViz -->
  <include file="$(find turtlebot3_manipulation_moveit_config)/launch/moveit_rviz.launch">
    <!-- Optional: pass arguments to moveit_rviz.launch if needed -->
    <!-- <arg name="config" value="true"/> -->
    <!-- <arg name="debug" value="false"/> -->
  </include>

</launch>